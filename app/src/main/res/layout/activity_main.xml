<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- ===== TOP BAR: App title and stats ===== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="20dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="WordWhisper"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="@color/textPrimary" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="end">

                <TextView
                    android:id="@+id/textStreak"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🔥 0 day streak"
                    android:textSize="12sp"
                    android:textColor="@color/accentOrange" />

                <TextView
                    android:id="@+id/textWordCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Words today: 0"
                    android:textSize="12sp"
                    android:textColor="@color/textSecondary" />

            </LinearLayout>

        </LinearLayout>

        <!-- ===== LABEL: Word of the Day ===== -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="✦ WORD OF THE DAY"
            android:textSize="11sp"
            android:textColor="@color/accentPurple"
            android:textStyle="bold"
            android:letterSpacing="0.15"
            android:layout_marginBottom="12dp" />

        <!-- ===== FLASHCARD ===== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_background"
            android:padding="24dp"
            android:layout_marginBottom="16dp"
            android:elevation="4dp">

            <!-- The main word -->
            <TextView
                android:id="@+id/textWord"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Petrichor"
                android:textSize="40sp"
                android:textStyle="bold"
                android:textColor="@color/textPrimary"
                android:fontFamily="serif"
                android:layout_marginBottom="8dp" />

            <!-- Pronunciation -->
            <TextView
                android:id="@+id/textPronunciation"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="/PET-ri-kor/"
                android:textSize="16sp"
                android:textColor="@color/accentPurple"
                android:layout_marginBottom="4dp" />

            <!-- Part of speech badge -->
            <TextView
                android:id="@+id/textPartOfSpeech"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Noun"
                android:textSize="12sp"
                android:textColor="@color/white"
                android:background="@drawable/badge_background"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="20dp" />

            <!-- Divider line -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/dividerColor"
                android:layout_marginBottom="20dp" />

            <!-- ===== HIDDEN SECTION (revealed when user taps) ===== -->
            <LinearLayout
                android:id="@+id/layoutDetails"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <!-- Definition label -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="DEFINITION"
                    android:textSize="10sp"
                    android:textColor="@color/textSecondary"
                    android:textStyle="bold"
                    android:letterSpacing="0.15"
                    android:layout_marginBottom="6dp" />

                <!-- Definition text -->
                <TextView
                    android:id="@+id/textDefinition"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="The pleasant smell that comes from the earth after rain."
                    android:textSize="17sp"
                    android:textColor="@color/textPrimary"
                    android:lineSpacingExtra="4dp"
                    android:layout_marginBottom="20dp" />

                <!-- Example label -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="EXAMPLE"
                    android:textSize="10sp"
                    android:textColor="@color/textSecondary"
                    android:textStyle="bold"
                    android:letterSpacing="0.15"
                    android:layout_marginBottom="6dp" />

                <!-- Example sentence -->
                <TextView
                    android:id="@+id/textExample"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="She breathed in the petrichor after the long drought finally broke."
                    android:textSize="15sp"
                    android:textColor="@color/textSecondary"
                    android:fontFamily="serif"
                    android:textStyle="italic"
                    android:lineSpacingExtra="4dp"
                    android:layout_marginBottom="20dp" />

                <!-- Origin label -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="WORD ORIGIN"
                    android:textSize="10sp"
                    android:textColor="@color/textSecondary"
                    android:textStyle="bold"
                    android:letterSpacing="0.15"
                    android:layout_marginBottom="6dp" />

                <!-- Origin text -->
                <TextView
                    android:id="@+id/textOrigin"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Origin: Greek: petra (stone) + ichor (fluid in the veins of gods)"
                    android:textSize="13sp"
                    android:textColor="@color/accentPurple"
                    android:lineSpacingExtra="4dp" />

            </LinearLayout>

            <!-- ===== REVEAL BUTTON (shown before card is flipped) ===== -->
            <Button
                android:id="@+id/buttonReveal"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="Reveal Definition"
                android:textSize="16sp"
                android:textColor="@color/white"
                android:backgroundTint="@color/accentPurple"
                android:stateListAnimator="@null" />

        </LinearLayout>

        <!-- ===== ACTION BUTTONS (below the card) ===== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="4dp">

            <!-- Bookmark button -->
            <Button
                android:id="@+id/buttonBookmark"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="☆ Save"
                android:textSize="14sp"
                android:textColor="@color/accentPurple"
                android:backgroundTint="@color/cardBackground"
                android:stateListAnimator="@null"
                android:layout_marginEnd="8dp" />

            <!-- Next Word button (only visible after reveal) -->
            <Button
                android:id="@+id/buttonNext"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="Next Word →"
                android:textSize="14sp"
                android:textColor="@color/white"
                android:backgroundTint="@color/accentGreen"
                android:stateListAnimator="@null"
                android:visibility="gone" />

        </LinearLayout>

        <!-- ===== BOTTOM TIP ===== -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="A new word awaits you every day. Tap 'Next Word' to explore more."
            android:textSize="12sp"
            android:textColor="@color/textSecondary"
            android:gravity="center"
            android:layout_marginTop="24dp"
            android:paddingBottom="12dp" />

    </LinearLayout>

</ScrollView>
